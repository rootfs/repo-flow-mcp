{
    "name": "repo-flow-mcp-client",
    "version": "0.1.0",
    "description": "Standalone PR-review CLI that drives repo-flow-mcp over MCP and a configurable OpenAI-compatible LLM. Designed to also run as a GitHub Action.",
    "type": "module",
    "bin": {
        "mcp-review": "./bin/mcp-review.mjs"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "start": "node bin/mcp-review.mjs"
    },
    "dependencies": {
        "@ai-sdk/azure": "^1.3.25",
        "@ai-sdk/openai": "^1.3.24",
        "@modelcontextprotocol/sdk": "^1.0.4",
        "@octokit/rest": "^22.0.1",
        "ai": "^4.3.19"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "typescript": "^5.6.3"
    },
    "engines": {
        "node": ">=20"
    }
}
